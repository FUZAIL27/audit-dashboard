NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://star36522253_db_user:f%4027.com@cluster0.lsuvfag.mongodb.net/audit_dashboard?retryWrites=true&w=majority&appName=Cluster0# JWT

# JWT — generate strong random values for these, e.g. `openssl rand -base64 48`
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — the deployed frontend's exact origin (no trailing slash).
# Comma-separate multiple allowed origins, e.g. a stable domain + a
# preview-deployment domain: "https://app.example.com,https://preview.example.com"
# `FRONTEND_URL` is accepted as an alias for this same value.
CLIENT_ORIGIN=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=5

# Uploads
MAX_UPLOAD_SIZE_MB=25
UPLOAD_BATCH_SIZE=1000

# Single administrator account, auto-created on server startup if it
# doesn't already exist. CHANGE BOTH before deploying to production —
# a startup warning is logged if either default is still in use.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123
